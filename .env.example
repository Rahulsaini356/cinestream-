# -----------------------------------------------------------------------------
# CineStream Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to .env.local for local development.
# DO NOT commit real API keys, passwords, or secrets to Git.

# 1. Database Connection Strings (PostgreSQL / Supabase)
# Connect to Supabase via connection pooling (Prisma transaction / runtime query URL)
DATABASE_URL="postgresql://username:password@host:6543/postgres?pgbouncer=true&connection_limit=3"

# Direct connection to database (Used for Prisma migrations & schema pushing)
DIRECT_URL="postgresql://username:password@host:5432/postgres"

# 2. NextAuth Authentication
# Application URL
NEXTAUTH_URL="http://localhost:3000"

# Secret key for JWT signing & session encryption (Generate with `openssl rand -hex 32`)
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# 3. TMDB (The Movie Database) API Configuration
TMDB_API_KEY="your_tmdb_api_key_here"

# 4. Email Service (Brevo / SMTP) Configuration
EMAIL_USER="your-email@example.com"
EMAIL_PASS="your-email-password-or-app-key"
BREVO_API_KEY="xkeysib-your-brevo-api-key-here"

# 5. OAuth Provider Credentials (Google)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret-here"

# 6. Public Client-Safe Variables (Prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_TELEGRAM_URL="https://t.me/cinestreamdigital"
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxxxxxxxxxx"
